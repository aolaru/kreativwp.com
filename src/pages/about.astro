---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="About | Kreativ WP"
  description="About Kreativ WP and our practical WordPress utility plugins."
  canonicalPath="/about/"
  ogTitle="About | Kreativ WP"
  ogDescription="Learn how Kreativ WP builds practical WordPress maintenance plugins."
  heroEyebrow="About"
  heroTitle="Kreativ WP"
  heroTagline="Utility-first WordPress plugins focused on long-term maintainability and practical outcomes."
  heroImageSrc="/kreativ-wp-logo-128.svg"
  heroImageAlt="Kreativ WP logo"
  currentPath="/about/"
>
  <section class="card plugin-details" aria-labelledby="mission-title">
    <h2 id="mission-title">Mission</h2>
    <article class="plugin-detail">
      <h3>Built for real maintenance work</h3>
      <p>Kreativ WP plugins are designed to help site owners and teams catch issues early, clean up faster, and maintain healthy content over time.</p>
    </article>
    <article class="plugin-detail">
      <h3>Simple workflows, clear output</h3>
      <p>Each tool is intentionally focused: scan, detect, and surface actionable insights without unnecessary complexity.</p>
    </article>
    <article class="plugin-detail">
      <h3>Part of KREATIV ecosystem</h3>
      <p>We build independent creative tools and web utilities with reliability and long-term support in mind.</p>
    </article>
  </section>

  <section class="launch-cta card" aria-labelledby="next-title">
    <h2 id="next-title">Next</h2>
    <p>Want to explore current plugins or contact us directly?</p>
    <p><a class="button-like" href="/">Back to Home</a></p>
    <p><a class="detail-link" href="/contact/">Contact</a></p>
  </section>
</BaseLayout>
