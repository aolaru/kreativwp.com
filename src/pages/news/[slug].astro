---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const newsPosts = await getCollection("news");
  return newsPosts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
---
<BaseLayout
  title={`${post.data.title} | Kreativ WP News`}
  description={post.data.description}
  canonicalPath={`/news/${post.id}.html`}
  ogTitle={post.data.title}
  ogDescription={post.data.metaDescription}
  ogType="article"
  heroEyebrow="News"
  heroTitle={post.data.title}
  heroTagline={`Published on ${post.data.publishedLabel}`}
  heroImageSrc="/kreativ-wp-logo-128.svg"
  heroImageAlt="Kreativ WP logo"
>
  <article class="card plugin-details" aria-labelledby="article-title">
    <h2 id="article-title">{post.data.sectionTitle}</h2>
    {post.data.items.map((item) => (
      <article class="plugin-detail">
        <h3>{item.title}</h3>
        <p>{item.body}</p>
      </article>
    ))}
  </article>

  <section class="launch-cta card" aria-labelledby="read-more-title">
    <h2 id="read-more-title">More Updates</h2>
    <p><a class="button-like" href="/news.html">Back to all news</a></p>
  </section>
</BaseLayout>
