---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const plugins = await getCollection("plugins");
  return plugins.map((plugin) => ({
    params: { slug: plugin.id },
    props: { plugin }
  }));
}

const { plugin } = Astro.props;
const lastLineLinksNews = plugin.data.ctaLines.map((line) =>
  line === "Follow our News page for release updates."
    ? 'Follow our <a class="detail-link" href="/news.html">News</a> page for release updates.'
    : line
);
---
<BaseLayout
  title={`${plugin.data.name} | Kreativ WP`}
  description={plugin.data.metaDescription}
  canonicalPath={`/plugins/${plugin.id}.html`}
  ogTitle={plugin.data.name}
  ogDescription={plugin.data.metaDescription}
  heroEyebrow="Plugin"
  heroTitle={plugin.data.name}
  heroTagline={plugin.data.description}
  heroImageSrc={plugin.data.thumb}
  heroImageAlt={plugin.data.imageAlt}
>
  <section class="card plugin-details" aria-labelledby="features-title">
    <h2 id="features-title">{plugin.data.detailTitle}</h2>
    {plugin.data.detailItems.map((item) => (
      <article class="plugin-detail">
        <h3>{item.title}</h3>
        <p>{item.body}</p>
      </article>
    ))}
  </section>

  <section class="launch-cta card" aria-labelledby="plugin-cta-title">
    <h2 id="plugin-cta-title">{plugin.data.ctaTitle}</h2>
    {lastLineLinksNews.map((line) => <p set:html={line} />)}
    {plugin.data.ctaHref && plugin.data.ctaLabel && (
      <p><a class="button-like" href={plugin.data.ctaHref} target="_blank" rel="noopener noreferrer">{plugin.data.ctaLabel}</a></p>
    )}
  </section>
</BaseLayout>
